# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
giulia-*.tar

# Environment files with secrets
.env
.env.local
.env.*.local

# MCP config (contains bearer token)
.mcp.json

# Built escripts
/giulia
/giulia.escript

# Burrito build output
/burrito_out/

# Downloaded binaries
*.zip

# Windows artifacts
nul

# Claude Code local settings
.claude/

# Personal launch scripts — copy start-local.bat.example for your own
start-local.bat
start-home.bat
start-work.bat

# Per-project Giulia cache (CubDB, embeddings)
.giulia/

# Generated reports (dynamic output, not source)
/reports/
# Personal env files
.env.home
.env.work
CLAUDE.md
