{
  "$description": "Registered enrichment sources. Each entry binds a tool atom to its parser module and carries tool-specific tunables. severity_map keys are tool-emitted categories/checks; values are info|warning|error. default_severity applies when severity_map has no entry. Adding a tool: write the parser, append an entry here, restart the daemon.",
  "sources": [
    {
      "tool": "credo",
      "module": "Giulia.Enrichment.Sources.Credo",
      "$severity_note": "Credo's 'warning' category is misleadingly named — these are real bugs (IEx.pry left in code, String.to_atom on user input, RaiseInsideRescue), not cautions. Map to error.",
      "severity_map": {
        "warning": "error",
        "design": "warning",
        "refactor": "warning",
        "readability": "info",
        "consistency": "info"
      },
      "default_severity": "info"
    },
    {
      "tool": "dialyzer",
      "module": "Giulia.Enrichment.Sources.Dialyzer",
      "$severity_note": "Dialyzer warning categories per dialyxir's 47-entry catalogue. :error = real type bugs (dead clauses, missing functions, invalid contracts, callback shape mismatches). :warning = spec/contract divergence and apply/call shape concerns. :info = unknown_* references (typically external deps the PLT doesn't know about — usually noise).",
      "severity_map": {
        "no_return": "error",
        "pattern_match": "error",
        "pattern_match_covered": "error",
        "guard_fail": "error",
        "guard_fail_pattern": "error",
        "negative_guard_fail": "error",
        "call_to_missing_function": "error",
        "callback_missing": "error",
        "callback_argument_type_mismatch": "error",
        "callback_type_mismatch": "error",
        "callback_spec_argument_type_mismatch": "error",
        "callback_spec_type_mismatch": "error",
        "callback_not_exported": "error",
        "function_application_no_function": "error",
        "function_application_arguments": "error",
        "improper_list_construction": "error",
        "exact_equality": "error",
        "record_construction": "error",
        "record_match": "error",
        "record_matching": "error",
        "invalid_contract": "error",
        "contract_with_opaque": "error",
        "map_update": "error",
        "binary_construction": "error",
        "callback_info_missing": "error",
        "contract_subtype": "warning",
        "contract_supertype": "warning",
        "contract_diff": "warning",
        "contract_range": "warning",
        "extra_range": "warning",
        "missing_range": "warning",
        "overlapping_contract": "warning",
        "unmatched_return": "warning",
        "unused_function": "warning",
        "app_call": "warning",
        "apply": "warning",
        "call": "warning",
        "call_with_opaque": "warning",
        "call_without_opaque": "warning",
        "opaque_equality": "warning",
        "opaque_guard": "warning",
        "opaque_match": "warning",
        "opaque_nonequality": "warning",
        "opaque_type_test": "warning",
        "unknown_behaviour": "info",
        "unknown_function": "info",
        "unknown_type": "info"
      },
      "default_severity": "warning"
    }
  ]
}
